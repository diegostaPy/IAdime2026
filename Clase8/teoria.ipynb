   "source": [
    "## Ejemplo 3: Clasificación Multiclase (MNIST)\n",
    "\n",
    "**Problema:** Clasificar dígitos manuscritos (0-9) usando una red neuronal."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from tensorflow.keras.datasets import mnist\n",
    "from tensorflow.keras.utils import to_categorical\n",
    "\n",
    "# Cargar MNIST\n",
    "(X_train_mnist, y_train_mnist), (X_test_mnist, y_test_mnist) = mnist.load_data()\n",
    "\n",
    "# Preprocesamiento\n",
    "X_train_mnist = X_train_mnist.reshape(-1, 784) / 255.0\n",
    "X_test_mnist = X_test_mnist.reshape(-1, 784) / 255.0\n",
    "y_train_mnist = to_categorical(y_train_mnist, 10)\n",
    "y_test_mnist = to_categorical(y_test_mnist, 10)\n",
    "\n",
    "print(f\"Entrenamiento: {X_train_mnist.shape}\")\n",
    "print(f\"Prueba: {X_test_mnist.shape}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Modelo multiclase\n",
    "model_multi = Sequential([\n",
    "    Dense(128, activation='relu', input_shape=(784,)),\n",
    "    Dropout(0.2),\n",
    "    Dense(64, activation='relu'),\n",
    "    Dropout(0.2),\n",
    "    Dense(10, activation='softmax')\n",
    "])\n",
    "\n",
    "model_multi.compile(optimizer='adam',\n",
    "                    loss='categorical_crossentropy',\n",
    "                    metrics=['accuracy'])\n",
    "\n",
    "history_multi = model_multi.fit(X_train_mnist, y_train_mnist,\n",
    "                                 epochs=20,\n",
    "                                 batch_size=128,\n",
    "                                 validation_split=0.1,\n",
    "                                 verbose=1)\n",
    "\n",
    "# Evaluación\n",
    "test_loss, test_acc = model_multi.evaluate(X_test_mnist, y_test_mnist, verbose=0)\n",
    "print(f\"\\nPrecisión en MNIST: {test_acc:.4f}\")"
   ]
