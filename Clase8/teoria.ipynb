   "source": [
    "## Ejemplo 2: Regresión con PyTorch\n",
    "\n",
    "**Problema:** Predecir valores continuos usando un dataset sintético."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import DataLoader, TensorDataset\n",
    "from sklearn.datasets import make_regression\n",
    "\n",
    "# Generar datos de regresión\n",
    "X_reg, y_reg = make_regression(n_samples=1000, n_features=10, noise=10, random_state=42)\n",
    "X_reg_train, X_reg_test, y_reg_train, y_reg_test = train_test_split(X_reg, y_reg, test_size=0.2, random_state=42)\n",
    "\n",
    "# Convertir a tensores\n",
    "X_train_t = torch.tensor(X_reg_train, dtype=torch.float32)\n",
    "y_train_t = torch.tensor(y_reg_train, dtype=torch.float32).view(-1,1)\n",
    "X_test_t = torch.tensor(X_reg_test, dtype=torch.float32)\n",
    "y_test_t = torch.tensor(y_reg_test, dtype=torch.float32).view(-1,1)\n",
    "\n",
    "# DataLoader\n",
    "train_dataset = TensorDataset(X_train_t, y_train_t)\n",
    "train_loader = DataLoader(train_dataset, batch_size=32, shuffle=True)\n",
    "\n",
    "# Definir modelo\n",
    "class RegressionNet(nn.Module):\n",
    "    def __init__(self, input_dim):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(input_dim, 64),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(64, 32),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(32, 1)\n",
    "        )\n",
    "    def forward(self, x):\n",
    "        return self.net(x)\n",
    "\n",
    "model_reg = RegressionNet(10)\n",
    "criterion = nn.MSELoss()\n",
    "optimizer = optim.Adam(model_reg.parameters(), lr=0.001)\n",
    "\n",
    "# Entrenamiento\n",
    "epochs = 100\n",
    "train_losses = []\n",
    "val_losses = []\n",
    "\n",
    "for epoch in range(epochs):\n",
    "    model_reg.train()\n",
    "    epoch_loss = 0\n",
    "    for inputs, labels in train_loader:\n",
    "        optimizer.zero_grad()\n",
    "        outputs = model_reg(inputs)\n",
    "        loss = criterion(outputs, labels)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        epoch_loss += loss.item()\n",
    "    train_losses.append(epoch_loss / len(train_loader))\n",
    "    \n",
    "    # Validación\n",
    "    model_reg.eval()\n",
    "    with torch.no_grad():\n",
    "        val_pred = model_reg(X_test_t)\n",
    "        val_loss = criterion(val_pred, y_test_t).item()\n",
    "    val_losses.append(val_loss)\n",
    "    \n",
    "    if (epoch+1) % 20 == 0:\n",
    "        print(f'Epoch {epoch+1}/{epochs}, Train Loss: {train_losses[-1]:.4f}, Val Loss: {val_loss:.4f}')\n",
    "\n",
    "# Evaluación final\n",
    "model_reg.eval()\n",
    "with torch.no_grad():\n",
    "    y_pred_reg = model_reg(X_test_t).numpy()\n",
    "    mse = np.mean((y_reg_test - y_pred_reg.flatten())**2)\n",
    "    print(f\"\\nMSE en prueba: {mse:.4f}\")\n",
    "    print(f\"RMSE en prueba: {np.sqrt(mse):.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualizar resultados de regresión\n",
    "plt.figure(figsize=(12,5))\n",
    "\n",
    "plt.subplot(1,2,1)\n",
    "plt.plot(train_losses, label='Training Loss')\n",
    "plt.plot(val_losses, label='Validation Loss')\n",
    "plt.title('Loss durante entrenamiento')\n",
    "plt.xlabel('Epoch')\n",
    "plt.ylabel('MSE Loss')\n",
    "plt.legend()\n",
    "\n",
    "plt.subplot(1,2,2)\n",
    "plt.scatter(y_reg_test, y_pred_reg, alpha=0.5)\n",
    "plt.plot([y_reg_test.min(), y_reg_test.max()], [y_reg_test.min(), y_reg_test.max()], 'r--', lw=2)\n",
    "plt.xlabel('Valores Reales')\n",
    "plt.ylabel('Predicciones')\n",
    "plt.title('Predicciones vs Valores Reales')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
