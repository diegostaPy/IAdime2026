   "source": [
    "## Ejemplo 4: Early Stopping y Dropout en PyTorch\n",
    "\n",
    "Demostración de técnicas de regularización."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class RegularizedNet(nn.Module):\n",
    "    def __init__(self, input_dim, hidden_dim=128, dropout_rate=0.3):\n",
    "        super().__init__()\n",
    "        self.fc1 = nn.Linear(input_dim, hidden_dim)\n",
    "        self.dropout1 = nn.Dropout(dropout_rate)\n",
    "        self.fc2 = nn.Linear(hidden_dim, hidden_dim // 2)\n",
    "        self.dropout2 = nn.Dropout(dropout_rate)\n",
    "        self.fc3 = nn.Linear(hidden_dim // 2, 1)\n",
    "        self.sigmoid = nn.Sigmoid()\n",
    "        \n",
    "    def forward(self, x):\n",
    "        x = torch.relu(self.fc1(x))\n",
    "        x = self.dropout1(x)\n",
    "        x = torch.relu(self.fc2(x))\n",
    "        x = self.dropout2(x)\n",
    "        x = self.sigmoid(self.fc3(x))\n",
    "        return x\n",
    "\n",
    "# Datos\n",
    "X_pt, y_pt = make_classification(n_samples=2000, n_features=20, random_state=42)\n",
    "X_pt_train, X_pt_test, y_pt_train, y_pt_test = train_test_split(X_pt, y_pt, test_size=0.2, random_state=42)\n",
    "\n",
    "# Tensores\n",
    "X_pt_train_t = torch.tensor(X_pt_train, dtype=torch.float32)\n",
    "y_pt_train_t = torch.tensor(y_pt_train, dtype=torch.float32).view(-1,1)\n",
    "X_pt_test_t = torch.tensor(X_pt_test, dtype=torch.float32)\n",
    "y_pt_test_t = torch.tensor(y_pt_test, dtype=torch.float32).view(-1,1)\n",
    "\n",
    "dataset_pt = TensorDataset(X_pt_train_t, y_pt_train_t)\n",
    "loader_pt = DataLoader(dataset_pt, batch_size=64, shuffle=True)\n",
    "\n",
    "# Modelo con dropout\n",
    "model_reg_pt = RegularizedNet(20, dropout_rate=0.3)\n",
    "criterion = nn.BCELoss()\n",
    "optimizer = optim.Adam(model_reg_pt.parameters(), lr=0.001)\n",
    "\n",
    "# Entrenamiento\n",
    "epochs = 50\n",
    "best_val_loss = float('inf')\n",
    "patience = 10\n",
    "patience_counter = 0\n",
    "\n",
    "for epoch in range(epochs):\n",
    "    model_reg_pt.train()\n",
    "    for inputs, labels in loader_pt:\n",
    "        optimizer.zero_grad()\n",
    "        outputs = model_reg_pt(inputs)\n",
    "        loss = criterion(outputs, labels)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "    \n",
    "    # Validación\n",
    "    model_reg_pt.eval()\n",
    "    with torch.no_grad():\n",
    "        val_pred = model_reg_pt(X_pt_test_t)\n",
    "        val_loss = criterion(val_pred, y_pt_test_t).item()\n",
    "    \n",
    "    # Early stopping\n",
    "    if val_loss < best_val_loss:\n",
    "        best_val_loss = val_loss\n",
    "        patience_counter = 0\n",
    "        torch.save(model_reg_pt.state_dict(), 'best_model.pt')\n",
    "    else:\n",
    "        patience_counter += 1\n",
    "        if patience_counter >= patience:\n",
    "            print(f\"Early stopping en epoch {epoch+1}\")\n",
    "            break\n",
    "    \n",
    "    if (epoch+1) % 10 == 0:\n",
    "        print(f'Epoch {epoch+1}, Loss: {loss.item():.4f}, Val Loss: {val_loss:.4f}')\n",
    "\n",
    "# Cargar mejor modelo\n",
    "model_reg_pt.load_state_dict(torch.load('best_model.pt'))\n",
    "model_reg_pt.eval()\n",
    "with torch.no_grad():\n",
    "    y_pred_pt = (model_reg_pt(X_pt_test_t).numpy() > 0.5).astype(int)\n",
    "    acc_pt = accuracy_score(y_pt_test, y_pred_pt)\n",
    print(f"\nPrecisión final del mejor modelo: {acc_pt:.4f}")
   }
  ],
  {
