    "## Comparación: MLP vs Regresión Logística\n",
    "\n",
    "Demostramos que un MLP (con capa oculta) puede superar a la regresión logística cuando los datos no son linealmente separables."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.datasets import make_moons\n",
    "\n",
    "# Datos no lineales (luna creciente)\n",
    "X_moons, y_moons = make_moons(n_samples=500, noise=0.1, random_state=42)\n",
    "X_moons_train, X_moons_test, y_moons_train, y_moons_test = train_test_split(X_moons, y_moons, test_size=0.2, random_state=42)\n",
    "\n",
    "# Regresión Logística\n",
    "lr = LogisticRegression()\n",
    "lr.fit(X_moons_train, y_moons_train)\n",
    "lr_acc = lr.score(X_moons_test, y_moons_test)\n",
    "\n",
    "# MLP con TensorFlow\n",
    "mlp_moons = Sequential([\n",
    "    Dense(10, activation='relu', input_shape=(2,)),\n",
    "    Dense(10, activation='relu'),\n",
    "    Dense(1, activation='sigmoid')\n",
    "])\n",
    "mlp_moons.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])\n",
    "mlp_moons.fit(X_moons_train, y_moons_train, epochs=100, verbose=0, validation_split=0.2)\n",
    "_, mlp_acc = mlp_moons.evaluate(X_moons_test, y_moons_test, verbose=0)\n",
    "\n",
    "print(f\"Regresión Logística (lineal): {lr_acc:.4f}\")\n",
    "print(f\"MLP (no lineal): {mlp_acc:.4f}\")\n",
    "\n",
    "# Visualizar fronteras\n",
    "def plot_decision_boundary_sklearn(model, X, y, title):\n",
    "    x_min, x_max = X[:,0].min() - 0.5, X[:,0].max() + 0.5\n",
    "    y_min, y_max = X[:,1].min() - 0.5, X[:,1].max() + 0.5\n",
    "    xx, yy = np.meshgrid(np.linspace(x_min, x_max, 100), np.linspace(y_min, y_max, 100))\n",
    "    Z = model.predict(np.c_[xx.ravel(), yy.ravel()])\n",
    "    Z = Z.reshape(xx.shape)\n",
    "    plt.contourf(xx, yy, Z, alpha=0.3, cmap='coolwarm')\n",
    "    plt.scatter(X[:,0], X[:,1], c=y, cmap='coolwarm', edgecolor='k')\n",
    "    plt.title(title)\n",
    "    plt.xlabel('x1')\n",
    "    plt.ylabel('x2')\n",
    "\n",
    "plt.figure(figsize=(12,5))\n",
    "plt.subplot(1,2,1)\n",
    "plot_decision_boundary_sklearn(lr, X_moons_test, y_moons_test, 'Regresión Logística')\n",
    "plt.subplot(1,2,2)\n",
    "# MLP necesita predicción de probabilidad\n",
    "Z = mlp_moons.predict(np.c_[xx.ravel(), yy.ravel()])\n",
    "Z = (Z > 0.5).astype(int).reshape(xx.shape)\n",
    "plt.contourf(xx, yy, Z, alpha=0.3, cmap='coolwarm')\n",
    "plt.scatter(X_moons_test[:,0], X_moons_test[:,1], c=y_moons_test, cmap='coolwarm', edgecolor='k')\n",
    "plt.title('MLP (2 capas ocultas)')\n",
    "plt.xlabel('x1')\n",
    "plt.ylabel('x2')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
